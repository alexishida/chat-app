<div class="container mx-auto p-4 max-w-lg text-center">
  <h1 class="text-3xl font-bold mb-6">Salas de Chat Disponíveis</h1>
  <div class="space-y-4">
    <% @rooms.each do |room| %>
      <%= link_to room.name, room_path(room), class: "w-full block py-3 px-6 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-lg shadow-md transition duration-300" %>
    <% end %>
  </div>
</div>
